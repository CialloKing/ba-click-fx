{
  "name": "ba-click-fx",
  "version": "1.0.6",
  "description": "网页版《蔚蓝档案》点击与拖拽特效，纯 Canvas 2D 实现，零外部依赖",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/ba-click-fx.cjs",
  "module": "./dist/ba-click-fx.js",
  "types": "./dist/ba-click-fx.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ba-click-fx.js",
      "require": "./dist/ba-click-fx.cjs",
      "types": "./dist/ba-click-fx.d.ts"
    }
  },
  "files": [
    "dist/ba-click-fx.js",
    "dist/ba-click-fx.cjs",
    "dist/ba-click-fx.iife.js",
    "dist/ba-click-fx.d.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "canvas",
    "animation",
    "particle",
    "trail",
    "click-effect",
    "blue-archive"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CialloKing/ba-click-fx.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs",
    "preview": "vite preview",
    "test": "node test/smoke.js"
  },
  "devDependencies": {
    "vite": "^8.1.1"
  }
}
