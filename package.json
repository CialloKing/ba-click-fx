{
  "name": "ba-click-fx",
  "version": "1.1.0",
  "description": "Blue Archive style mouse click effect and cursor trail animation for web Canvas.",
  "author": "CialloKing",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/ba-click-fx.cjs",
  "module": "./dist/ba-click-fx.js",
  "types": "./dist/ba-click-fx.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ba-click-fx.js",
      "require": "./dist/ba-click-fx.cjs",
      "types": "./dist/ba-click-fx.d.ts"
    }
  },
  "files": [
    "dist/ba-click-fx.js",
    "dist/ba-click-fx.cjs",
    "dist/ba-click-fx.iife.js",
    "dist/ba-click-fx.d.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "blue-archive",
    "bluearchive",
    "ba",
    "click-effect",
    "mouse-effect",
    "cursor-effect",
    "touch-effect",
    "trail-effect",
    "cursor-trail",
    "canvas",
    "canvas2d",
    "javascript",
    "web-animation",
    "particle-effect",
    "anime-ui",
    "game-ui"
  ],
  "homepage": "https://ba-click-fx.cialloking.top",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CialloKing/ba-click-fx.git"
  },
  "bugs": {
    "url": "https://github.com/CialloKing/ba-click-fx/issues"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs",
    "preview": "vite preview",
    "test": "node test/smoke.js"
  },
  "devDependencies": {
    "vite": "^8.1.1"
  }
}
